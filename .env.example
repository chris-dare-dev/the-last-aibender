# the-last-aibender — example environment file (committed; placeholders ONLY)
# Copy to `.env` (gitignored) and fill in real values there — never here.
#
# ############################################################################
# # WARNING — AWS_PROFILE values EMBED the AWS account ID.                   #
# # SSO-generated profile names look like <account-id>_<RoleName>, so the    #
# # real profile name is itself an identifier leak. The literal profile      #
# # name must NEVER appear in any committed file. Set it only in your local  #
# # .env, shell config, or Keychain. In the tree the account is always the   #
# # placeholder AWS_DEV_ACCOUNT_ID.                                          #
# ############################################################################
AWS_PROFILE=AWS_DEV_ACCOUNT_ID_AdministratorAccess
AWS_REGION=us-east-1

# Account identity policy (X2): MAX_A / MAX_B / ENT are the ONLY identities
# ever persisted in this repo, its DBs, logs, and exports. The label→real
# account mapping is resolved at runtime from machine-local config/Keychain
# (under ~/.aibender/) and is never serialized into the tree.
AIBENDER_ACCOUNT_LABELS=MAX_A,MAX_B,ENT

# Machine-local root for runtime state (accounts, db, bootstrap, logs).
# Real values (account mapping, tier-2 scanner literals) live ONLY here.
AIBENDER_HOME=~/.aibender

# Dev-mode runtime data inside the working tree stays under gitignored var/.
AIBENDER_VAR_DIR=./var
