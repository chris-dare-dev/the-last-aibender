{
  "name": "aibender-core",
  "version": "0.0.0",
  "private": true,
  "description": "The aibender-core broker daemon (blueprint §2): session kernel, gateway, adapters, collector, workstreams, pipelines. M1: BE-1 session kernel & account runtime (core/src/kernel/).",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "@aibender/protocol": "workspace:*",
    "@aibender/schema": "workspace:*",
    "@aibender/shared": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "0.3.201",
    "@opencode-ai/sdk": "1.17.13",
    "node-pty": "1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@aibender/testkit": "workspace:*",
    "@types/ws": "^8.18.0"
  },
  "scripts": {
    "postinstall": "node scripts/fix-spawn-helper.mjs",
    "demo:m1": "tsx scripts/demo-m1.ts",
    "soak:m2": "tsx scripts/m2-soak/run.ts",
    "soak:m6": "tsx scripts/m6-supervision-soak/run.ts",
    "start": "tsx src/main/index.ts",
    "boot": "tsx src/main/index.ts boot",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  }
}
