{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "{{OTLP_ENDPOINT}}",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_RESOURCE_ATTRIBUTES": "account={{ACCOUNT_LABEL}}",
    "OTEL_METRICS_INCLUDE_ACCOUNT_UUID": "false"
  },
  "statusLine": {
    "type": "command",
    "command": "{{STATUSLINE_COMMAND}}",
    "padding": 0
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }]
      }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "Setup": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "UserPromptExpansion": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "StopFailure": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }]
      }
    ],
    "PostToolBatch": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "PermissionRequest": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "PermissionDenied": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "SubagentStart": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "SubagentStop": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "TeammateIdle": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "TaskCreated": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "TaskCompleted": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "FileChanged": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "CwdChanged": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "InstructionsLoaded": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "ConfigChange": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "WorktreeCreate": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "WorktreeRemove": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "PreCompact": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "PostCompact": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "Notification": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "MessageDisplay": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ],
    "Elicitation": [
      { "hooks": [{ "type": "http", "url": "{{HOOKS_URL}}", "timeout": 5 }] }
    ]
  }
}
